meta {
  name: revokeUserSession
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/admin/revoke-user-session
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "sessionToken": ""
  }
}

example {
  name: 200 Response
  description: Session revoked
  
  request: {
    url: {{baseUrl}}/admin/revoke-user-session
    method: POST
    mode: json
    body:json: {
      {
        "sessionToken": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "success": false
        }
      '''
    }
  }
}

