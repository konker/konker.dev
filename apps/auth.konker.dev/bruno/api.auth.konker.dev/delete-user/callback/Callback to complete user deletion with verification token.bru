meta {
  name: Callback to complete user deletion with verification token
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/delete-user/callback
  body: none
  auth: bearer
}

params:query {
  ~token: 
  ~callbackURL: 
}

auth:bearer {
  token: {{token}}
}

example {
  name: 200 Response
  description: User successfully deleted
  
  request: {
    url: {{baseUrl}}/delete-user/callback
    method: GET
    mode: none
    params:query: {
      ~token: 
      ~callbackURL: 
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "success": false,
          "message": ""
        }
      '''
    }
  }
}

