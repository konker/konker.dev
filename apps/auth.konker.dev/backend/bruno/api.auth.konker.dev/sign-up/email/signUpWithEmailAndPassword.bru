meta {
  name: signUpWithEmailAndPassword
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/sign-up/email
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "",
    "email": "",
    "password": "",
    "image": "",
    "callbackURL": "",
    "rememberMe": false
  }
}

example {
  name: 200 Response
  description: Successfully created user
  
  request: {
    url: {{baseUrl}}/sign-up/email
    method: POST
    mode: json
    body:json: {
      {
        "name": "",
        "email": "",
        "password": "",
        "image": "",
        "callbackURL": "",
        "rememberMe": false
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "token": "",
          "user": {
            "id": "",
            "email": "",
            "name": "",
            "image": "",
            "emailVerified": false,
            "createdAt": "",
            "updatedAt": ""
          }
        }
      '''
    }
  }
}

