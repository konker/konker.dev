meta {
  name: Get OAuth2 user information
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/oauth2/userinfo
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

example {
  name: 200 Response
  description: User information retrieved successfully
  
  request: {
    url: {{baseUrl}}/oauth2/userinfo
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "sub": "",
          "email": "",
          "name": "",
          "picture": "",
          "given_name": "",
          "family_name": "",
          "email_verified": false
        }
      '''
    }
  }
}

