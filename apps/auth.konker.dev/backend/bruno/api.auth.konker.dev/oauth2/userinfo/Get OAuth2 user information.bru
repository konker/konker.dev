  name: 400 Response
  description: Bad Request. Usually due to missing parameters, or invalid parameters.
  
  request: {
    url: {{baseUrl}}/oauth2/userinfo
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 400
      text: Bad Request
    }
  
    body: {
      type: json
      content: '''
        {
          "message": ""
        }
      '''
    }
  }
}

