meta {
  name: Register an OAuth2 application
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/oauth2/register
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "redirect_uris": [],
    "token_endpoint_auth_method": "",
    "grant_types": "",
    "response_types": "",
    "client_name": "",
    "client_uri": "",
    "logo_uri": "",
    "scope": "",
    "contacts": "",
    "tos_uri": "",
    "policy_uri": "",
    "jwks_uri": "",
    "jwks": "",
    "metadata": "",
    "software_id": "",
    "software_version": "",
    "software_statement": ""
  }
}

example {
  name: 200 Response
  description: OAuth2 application registered successfully
  
  request: {
    url: {{baseUrl}}/oauth2/register
    method: POST
    mode: json
    body:json: {
      {
        "redirect_uris": [],
        "token_endpoint_auth_method": "",
        "grant_types": "",
        "response_types": "",
        "client_name": "",
        "client_uri": "",
        "logo_uri": "",
        "scope": "",
        "contacts": "",
        "tos_uri": "",
        "policy_uri": "",
        "jwks_uri": "",
        "jwks": "",
        "metadata": "",
        "software_id": "",
        "software_version": "",
        "software_statement": ""
      }
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "name": "",
          "icon": "",
          "metadata": {},
          "clientId": "",
          "clientSecret": "",
          "redirectURLs": [],
          "type": "",
          "authenticationScheme": "",
          "disabled": false,
          "userId": "",
          "createdAt": "",
          "updatedAt": ""
        }
      '''
    }
  }
}

