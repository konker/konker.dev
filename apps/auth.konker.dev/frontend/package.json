{
  "name": "@konker.dev/auth.konker.dev",
  "version": "0.0.1",
  "type": "module",
  "author": "Konrad Markus <mail@konker.dev>",
  "license": "ISC",
  "description": "Authentication service for konker.dev services",
  "homepage": "https://konker.dev/",
  "keywords": [
    "node",
    "utils",
    "typescript",
    "functional-programming",
    "effect-ts",
    "auth"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/konker.dev/apps/auth.konker.dev"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.test.*"
  ],
  "main": "dist/index.js",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.51.4",
    "@hcaptcha/react-hcaptcha": "^1.12.1",
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.1.0",
    "@noble/hashes": "^2.0.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@wojtekmaj/react-recaptcha-v3": "^0.1.4",
    "astro": "^5.17.1",
    "better-auth": "^1.4.18",
    "better-auth-ui": "^3.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.544.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.65.0",
    "react-qr-code": "^2.0.18",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ua-parser-js": "^2.0.5",
    "vaul": "^1.1.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@astrojs/react": "^4.4.2",
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^9.39.2",
    "@konker.dev/common-config": "^0.7.0",
    "@konker.dev/config-o-tron": "0.0.2",
    "@tailwindcss/vite": "^4.1.12",
    "@types/node": "^25.0.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-istanbul": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-plugin-fp": "^2.3.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "leasot": "^14.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.7.4",
    "shadcn": "^3.8.5",
    "sst": "^3.17.25",
    "tailwindcss": "^4.1.12",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.16"
  },
  "scripts": {
    "build": "pnpm run clean && astro build",
    "build:prod": "pnpm run build && pnpm deploy --filter @konker.dev/auth.konker.dev --prod ./.deploy",
    "build-container": "pnpm run build:prod && docker buildx build -t $AWS_ECR_REGISTRY/$AWS_ECR_REPOSITORY:$IMAGE_TAG -f ./deployment/Dockerfile ..",
    "push-container": "aws ecr get-login-password --region ${AWS_DEFAULT_REGION:-eu-west-1} | docker login --username AWS --password-stdin $AWS_ECR_REGISTRY && docker push $AWS_ECR_REGISTRY/$AWS_ECR_REPOSITORY:$IMAGE_TAG",
    "dev": "astro dev",
    "preview": "astro preview",
    "ci": "pnpm run lint-check && pnpm run typecheck && pnpm run type-coverage-check && pnpm run test && pnpm run build && pnpm run fixme-check",
    "cd": "echo NOOP",
    "circular-check": "madge --extensions ts --circular --no-color --no-spinner --warning src",
    "clean": "rm -rf dist && rm -rf .deploy && rm -f tsconfig.tsbuildinfo",
    "codecov": "npx --package=@konker.dev/common-config codecov-upload `pwd` '@konker.dev/auth.konker.dev'",
    "eslint-check": "eslint --max-warnings=0 '**/*.{ts,js,json}'",
    "eslint-fix": "npx eslint --fix||true",
    "fixme-check": "leasot --exit-nicely --skip-unsupported src",
    "lint-check": "pnpm run eslint-check && pnpm run prettier-check && pnpm run circular-check && pnpm run fixme-check",
    "lint-fix": "pnpm run eslint-fix && pnpm run prettier-fix",
    "pre-push": "pnpm run lint-check && pnpm run typecheck",
    "prettier-check": "npx prettier --check --ignore-path .gitignore --ignore-path .prettierignore '**/*.{css,html,js,ts,json,md,yaml,yml}'",
    "prettier-fix": "pnpm run prettier-check --write",
    "test": "vitest run --coverage",
    "type-coverage-check": "type-coverage --detail --at-least 99 --ignore-files src/index.test.ts",
    "typecheck": "tsc --noEmit"
  }
}
