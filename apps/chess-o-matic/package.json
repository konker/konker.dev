{
  "name": "chess-voice-recognition-browser",
  "version": "1.0.0",
  "description": "Chess move voice recognition using Vosk in the browser",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist && rm -rf coverage && rm -f tsconfig.tsbuildinfo",
    "type-coverage-check": "type-coverage --detail --at-least 100",
    "circular-check": "madge --extensions ts --circular --no-color --no-spinner --warning --ts-config ./tsconfig.json src",
    "eslint-check": "eslint --max-warnings=0 'src/**/*.{ts,js,json}'",
    "fixme-check": "leasot --exit-nicely --skip-unsupported --ignore node_modules src",
    "eslint-fix": "npx eslint --fix||true",
    "prettier-check": "npx prettier --check --ignore-path .gitignore --ignore-path .prettierignore '**/*.{css,html,js,ts,json,md,yaml,yml}'",
    "prettier-fix": "pnpm run prettier-check --write",
    "lint-check": "pnpm run eslint-check && pnpm run prettier-check && pnpm run circular-check && pnpm run fixme-check",
    "lint-fix": "pnpm run eslint-fix && pnpm run prettier-fix",
    "pre-push": "pnpm run lint-check && pnpm run typecheck && pnpm run build",
    "ci": "pnpm run lint-check && pnpm run build && pnpm run typecheck"
  },
  "keywords": [
    "chess",
    "voice-recognition",
    "vosk",
    "speech-recognition",
    "browser"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chess.js": "^1.4.0",
    "gchessboard": "^1.4.0",
    "vosk-browser": "^0.0.8"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@effect/language-service": "^0.64.1",
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^9.39.2",
    "@konker.dev/common-config": "^0.8.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitest/coverage-istanbul": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-plugin-fp": "^2.3.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "leasot": "^14.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.7.4",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vite": "^7.2.4",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.16"
  }
}
