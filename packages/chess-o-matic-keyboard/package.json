{
  "name": "@konker.dev/chess-o-matic-keyboard",
  "version": "0.0.1",
  "type": "module",
  "author": "Konrad Markus <mail@konker.dev>",
  "license": "ISC",
  "description": "Headless chess move-entry core with SolidJS UI components for mobile and tablet keyboards",
  "homepage": "https://konker.dev/",
  "keywords": [
    "chess",
    "keyboard",
    "solidjs",
    "tauri",
    "mobile",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/konker/konker.dev/packages/chess-o-matic-keyboard"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./solid": {
      "types": "./dist/solid/index.d.ts",
      "import": "./dist/solid/index.js"
    },
    "./adapters/chessjs": {
      "types": "./dist/adapters/chessjs.d.ts",
      "import": "./dist/adapters/chessjs.js"
    }
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.test.*"
  ],
  "main": "dist/index.js",
  "peerDependencies": {
    "chess.js": "^1.4.0",
    "solid-js": "^1.9.12"
  },
  "peerDependenciesMeta": {
    "chess.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@effect/language-service": "^0.64.1",
    "@eslint/compat": "^2.0.1",
    "@eslint/js": "^9.39.2",
    "@konker.dev/common-config": "^0.8.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.6",
    "@vitest/coverage-istanbul": "^4.0.16",
    "chess.js": "^1.4.0",
    "eslint": "^9.39.2",
    "eslint-plugin-fp": "^2.3.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "jsdom": "^26.1.0",
    "leasot": "^14.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.7.4",
    "solid-js": "^1.9.12",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^4.0.16"
  },
  "scripts": {
    "test": "vitest run --coverage",
    "clean": "rm -rf dist && rm -rf coverage && rm -f tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run clean && tsup",
    "type-coverage-check": "type-coverage --detail --at-least 95 --ignore-files src/index.ts --ignore-files src/solid/index.ts",
    "circular-check": "madge --extensions ts,tsx --circular --no-color --no-spinner --warning --ts-config ./tsconfig.json src",
    "eslint-check": "eslint --max-warnings=0 'src/**/*.{ts,tsx,js,json}'",
    "eslint-fix": "npx eslint --fix||true",
    "generated-exports-check": "npx --package=@konker.dev/common-config generate-exports-verify `pwd`",
    "exports-check": "attw --pack . --ignore-rules=cjs-resolves-to-esm --profile=node16",
    "fixme-check": "leasot --exit-nicely --skip-unsupported src",
    "prettier-check": "npx prettier --check --ignore-path .gitignore --ignore-path .prettierignore '**/*.{css,html,js,jsx,ts,tsx,json,md,yaml,yml}'",
    "prettier-fix": "pnpm run prettier-check --write",
    "lint-check": "pnpm run eslint-check && pnpm run prettier-check && pnpm run circular-check && pnpm run fixme-check",
    "lint-fix": "pnpm run eslint-fix && pnpm run prettier-fix",
    "pre-push": "pnpm run lint-check && pnpm run typecheck",
    "codecov": "npx --package=@konker.dev/common-config codecov-upload `pwd` '@konker.dev/chess-o-matic-keyboard'",
    "ci": "pnpm run lint-check && pnpm run typecheck && pnpm run type-coverage-check && pnpm run test && pnpm run build && pnpm run generated-exports-check && pnpm run exports-check && pnpm run fixme-check",
    "cd": "pnpm run build && npx --package=@konker.dev/common-config npm-publish-if-version-not-exists `pwd`"
  }
}
